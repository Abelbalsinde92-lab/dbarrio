<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>QR dbarrio — WhatsApp</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800;900&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#1A1A2E;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px;font-family:'DM Sans',sans-serif;gap:40px}

.controls{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;max-width:640px}
.ctrl-btn{padding:9px 18px;border-radius:8px;border:1.5px solid rgba(255,255,255,.15);background:transparent;color:rgba(255,255,255,.6);font-size:12px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;letter-spacing:.3px;transition:all .15s}
.ctrl-btn:hover{background:rgba(255,255,255,.08);color:#fff}
.ctrl-btn.active{background:#F5C116;border-color:#F5C116;color:#0F0F1A}

.export-row{display:flex;gap:10px;justify-content:center}
.export-btn{padding:10px 22px;border-radius:8px;border:none;font-size:13px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s}
.btn-dl{background:#F5C116;color:#0F0F1A}
.btn-dl:hover{opacity:.9}
.btn-copy{background:rgba(255,255,255,.1);color:#fff;border:1.5px solid rgba(255,255,255,.15)}
.btn-copy:hover{background:rgba(255,255,255,.16)}

.hint{font-size:11px;color:rgba(255,255,255,.3);text-align:center;line-height:1.7;max-width:420px}
.hint strong{color:rgba(255,255,255,.6)}

/* ── TARJETAS ── */
.cards-row{display:flex;flex-wrap:wrap;gap:24px;justify-content:center}
.card-wrap{display:flex;flex-direction:column;align-items:center;gap:8px}
.card-label{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.3)}

/* VARIANTE NEGRA */
.qr-card-dark{
  width:320px;background:#0F0F1A;
  border:2px solid rgba(245,193,22,.2);
  border-radius:16px;padding:24px 24px 20px;
  display:flex;flex-direction:column;align-items:center;gap:0;
  position:relative;overflow:hidden;
}
.qr-card-dark::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:#F5C116}

/* VARIANTE AMARILLA */
.qr-card-yellow{
  width:320px;background:#F5C116;
  border-radius:16px;padding:24px 24px 20px;
  display:flex;flex-direction:column;align-items:center;gap:0;
  position:relative;overflow:hidden;
}

/* VARIANTE CREMA */
.qr-card-cream{
  width:320px;background:#F2EFE9;
  border:2px solid #0F0F1A;
  border-radius:16px;padding:24px 24px 20px;
  display:flex;flex-direction:column;align-items:center;gap:0;
  position:relative;overflow:hidden;
}
.qr-card-cream::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:#0F0F1A}

/* COMPACTO (para pegar en posts) */
.qr-card-compact{
  width:200px;background:#0F0F1A;
  border:1.5px solid #F5C116;
  border-radius:12px;padding:16px;
  display:flex;flex-direction:column;align-items:center;gap:0;
}

.qr-frame{border-radius:10px;overflow:hidden;display:block;margin-bottom:14px}
.qr-frame canvas{display:block}

.brand-row{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.brand-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.brand-icon-dark{background:rgba(245,193,22,.15);border:1px solid rgba(245,193,22,.25)}
.brand-icon-yellow{background:rgba(15,15,26,.15);border:1px solid rgba(15,15,26,.15)}
.brand-icon-cream{background:#0F0F1A}
.brand-letters{font-family:'Barlow Condensed',sans-serif;font-size:17px;font-weight:900;letter-spacing:-1px;line-height:1}
.brand-name{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:900;letter-spacing:-.5px;line-height:1}

.qr-title{font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:900;letter-spacing:-.2px;margin-bottom:3px;text-align:center}
.qr-sub{font-size:11px;font-weight:600;letter-spacing:.5px;text-align:center;margin-bottom:0}
.qr-wa-num{font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:900;letter-spacing:.5px;text-align:center;margin-top:8px}

/* Dark colors */
.qr-card-dark .qr-title{color:#fff}
.qr-card-dark .qr-sub{color:rgba(255,255,255,.4)}
.qr-card-dark .qr-wa-num{color:rgba(255,255,255,.3)}
.qr-card-dark .brand-letters .d{color:#E0E0F0}
.qr-card-dark .brand-letters .b{color:#F5C116}
.qr-card-dark .brand-name .d{color:#E0E0F0}
.qr-card-dark .brand-name .rest{color:#F5C116}

/* Yellow colors */
.qr-card-yellow .qr-title{color:#0F0F1A}
.qr-card-yellow .qr-sub{color:rgba(15,15,26,.5)}
.qr-card-yellow .qr-wa-num{color:rgba(15,15,26,.4)}
.qr-card-yellow .brand-letters .d{color:#0F0F1A}
.qr-card-yellow .brand-letters .b{color:rgba(15,15,26,.7)}
.qr-card-yellow .brand-name .d{color:#0F0F1A}
.qr-card-yellow .brand-name .rest{color:rgba(15,15,26,.7)}

/* Cream colors */
.qr-card-cream .qr-title{color:#0F0F1A}
.qr-card-cream .qr-sub{color:#5A5A6E}
.qr-card-cream .qr-wa-num{color:#9A96A0}
.qr-card-cream .brand-letters .d{color:#E0E0F0}
.qr-card-cream .brand-letters .b{color:#F5C116}
.qr-card-cream .brand-name .d{color:#0F0F1A}
.qr-card-cream .brand-name .rest{color:#C9980D}

/* Compact */
.qr-card-compact .qr-title{font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:900;color:#fff;text-align:center;margin-bottom:2px}
.qr-card-compact .qr-sub{font-size:9px;font-weight:700;color:rgba(255,255,255,.4);letter-spacing:.5px;text-align:center}
</style>
</head>
<body>

<div class="cards-row" id="cardsRow">

  <!-- VARIANTE OSCURA -->
  <div class="card-wrap">
    <div class="card-label">Oscura</div>
    <div class="qr-card-dark" id="card-dark">
      <div class="brand-row" style="margin-bottom:16px">
        <div class="brand-icon brand-icon-dark">
          <span class="brand-letters"><span class="d">d</span><span class="b">b</span></span>
        </div>
        <span class="brand-name"><span class="d">d</span><span class="rest">barrio</span></span>
      </div>
      <canvas class="qr-frame" id="qr-dark"></canvas>
      <div class="qr-title">Escríbenos por WhatsApp</div>
      <div class="qr-sub" style="text-transform:uppercase;letter-spacing:1.5px">Técnicos verificados · La Habana</div>
      <div class="qr-wa-num">wa.me/34627493593</div>
    </div>
  </div>

  <!-- VARIANTE AMARILLA -->
  <div class="card-wrap">
    <div class="card-label">Amarilla</div>
    <div class="qr-card-yellow" id="card-yellow">
      <div class="brand-row" style="margin-bottom:16px">
        <div class="brand-icon brand-icon-yellow">
          <span class="brand-letters"><span class="d">d</span><span class="b">b</span></span>
        </div>
        <span class="brand-name"><span class="d">d</span><span class="rest">barrio</span></span>
      </div>
      <canvas class="qr-frame" id="qr-yellow"></canvas>
      <div class="qr-title">Escríbenos por WhatsApp</div>
      <div class="qr-sub" style="text-transform:uppercase;letter-spacing:1.5px">Técnicos verificados · La Habana</div>
      <div class="qr-wa-num">wa.me/34627493593</div>
    </div>
  </div>

  <!-- VARIANTE CREMA -->
  <div class="card-wrap">
    <div class="card-label">Crema</div>
    <div class="qr-card-cream" id="card-cream">
      <div class="brand-row" style="margin-bottom:16px">
        <div class="brand-icon brand-icon-cream">
          <span class="brand-letters" style="color:#E0E0F0"><span class="d">d</span><span class="b" style="color:#F5C116">b</span></span>
        </div>
        <span class="brand-name"><span class="d">d</span><span class="rest">barrio</span></span>
      </div>
      <canvas class="qr-frame" id="qr-cream"></canvas>
      <div class="qr-title">Escríbenos por WhatsApp</div>
      <div class="qr-sub" style="text-transform:uppercase;letter-spacing:1.5px">Técnicos verificados · La Habana</div>
      <div class="qr-wa-num">wa.me/34627493593</div>
    </div>
  </div>

  <!-- COMPACTO PARA POSTS -->
  <div class="card-wrap">
    <div class="card-label">Compacto (para posts)</div>
    <div class="qr-card-compact" id="card-compact">
      <canvas id="qr-compact" style="border-radius:8px;display:block;margin-bottom:10px"></canvas>
      <div class="qr-title">Contáctanos</div>
      <div class="qr-sub">WHATSAPP · dbarrio</div>
    </div>
  </div>

</div>

<div class="controls" id="ctrlRow">
  <span style="font-size:11px;font-weight:700;color:rgba(255,255,255,.3);letter-spacing:1px;text-transform:uppercase;align-self:center">Texto:</span>
  <button class="ctrl-btn active" data-txt="Escríbenos por WhatsApp">WhatsApp</button>
  <button class="ctrl-btn" data-txt="Solicita tu técnico ahora">Solicita técnico</button>
  <button class="ctrl-btn" data-txt="Servicio a domicilio · 24h">Servicio 24h</button>
  <button class="ctrl-btn" data-txt="Garantía en todos los trabajos">Con garantía</button>
</div>

<div class="export-row">
  <button class="export-btn btn-dl" onclick="downloadAll()">Descargar todas (PNG)</button>
  <button class="export-btn btn-copy" onclick="copyLink()">Copiar enlace WA</button>
</div>

<p class="hint">
  <strong>Para pegar en tus publicaciones:</strong> usa la variante Compacta (200px) en la esquina de cualquier plantilla.<br/>
  Las variantes grandes son para stickers físicos, flyers y cartas de presentación.<br/>
  Todos los QR apuntan a <strong>wa.me/34627493593</strong>
</p>

<script>
const WA_URL = 'https://wa.me/34627493593?text=Hola%2C+vengo+de+dbarrio.+';

const configs = [
  { id: 'qr-dark',    size: 220, dark: '#0F0F1A', light: '#0F0F1A', fg: '#F5C116', bg: '#0F0F1A' },
  { id: 'qr-yellow',  size: 220, fg: '#0F0F1A',   bg: '#F5C116' },
  { id: 'qr-cream',   size: 220, fg: '#0F0F1A',   bg: '#F2EFE9' },
  { id: 'qr-compact', size: 148, fg: '#F5C116',   bg: '#0F0F1A' },
];

function renderAll() {
  configs.forEach(c => {
    QRCode.toCanvas(document.getElementById(c.id), WA_URL, {
      width: c.size,
      margin: 2,
      color: { dark: c.fg, light: c.bg },
      errorCorrectionLevel: 'H'
    });
  });
}

renderAll();

// Cambio de texto (solo visual en tarjetas)
document.querySelectorAll('.ctrl-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.ctrl-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const txt = btn.dataset.txt;
    document.querySelectorAll('.qr-title').forEach(el => {
      if (el.closest('.qr-card-compact')) return;
      el.textContent = txt;
    });
  });
});

// Descargar todas
async function downloadAll() {
  const cards = [
    { id: 'card-dark',    name: 'dbarrio-qr-oscuro' },
    { id: 'card-yellow',  name: 'dbarrio-qr-amarillo' },
    { id: 'card-cream',   name: 'dbarrio-qr-crema' },
    { id: 'card-compact', name: 'dbarrio-qr-compacto' },
  ];

  for (const card of cards) {
    const el = document.getElementById(card.id);
    const canvas = await htmlToCanvas(el);
    const link = document.createElement('a');
    link.download = card.name + '.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
    await new Promise(r => setTimeout(r, 400));
  }
}

// Fallback manual canvas render para descarga
async function htmlToCanvas(el) {
  // Usar html2canvas si está disponible, sino solo el QR canvas
  const qrCanvas = el.querySelector('canvas');
  if (!qrCanvas) return;

  const w = el.offsetWidth || 320;
  const h = el.offsetHeight || 400;
  const out = document.createElement('canvas');
  out.width = w * 2;
  out.height = h * 2;
  const ctx = out.getContext('2d');
  ctx.scale(2, 2);

  // Fondo
  const style = getComputedStyle(el);
  ctx.fillStyle = style.backgroundColor || '#0F0F1A';
  ctx.roundRect(0, 0, w, h, 14);
  ctx.fill();

  // Barra superior (si dark o cream)
  if (el.classList.contains('qr-card-dark') || el.classList.contains('qr-card-compact')) {
    ctx.fillStyle = '#F5C116';
    ctx.fillRect(0, 0, w, 4);
  }
  if (el.classList.contains('qr-card-cream')) {
    ctx.fillStyle = '#0F0F1A';
    ctx.fillRect(0, 0, w, 4);
  }

  // QR centrado
  const qrSize = qrCanvas.width;
  const scale = qrCanvas.width / (qrCanvas.offsetWidth || qrCanvas.width);
  const qrDrawW = qrCanvas.offsetWidth || (qrSize / 2);
  const qrDrawH = qrCanvas.offsetHeight || (qrSize / 2);
  const qrX = (w - qrDrawW) / 2;

  // Fondo blanco detrás del QR si es tarjeta oscura
  if (el.classList.contains('qr-card-dark') || el.classList.contains('qr-card-compact')) {
    ctx.fillStyle = '#0F0F1A';
    ctx.roundRect(qrX - 4, 60, qrDrawW + 8, qrDrawH + 8, 8);
    ctx.fill();
  }
  ctx.drawImage(qrCanvas, qrX, 64, qrDrawW, qrDrawH);

  return out;
}

function copyLink() {
  navigator.clipboard.writeText('https://wa.me/34627493593').then(() => {
    const btn = document.querySelector('.btn-copy');
    const orig = btn.textContent;
    btn.textContent = '✓ Copiado';
    setTimeout(() => btn.textContent = orig, 1800);
  });
}
</script>
</body>
</html>
